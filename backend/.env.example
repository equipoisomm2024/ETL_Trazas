# .env.example — Copiar a .env y ajustar los valores
# IMPORTANTE: No incluir .env en control de versiones

# Base de datos
DATABASE_URL=postgresql+psycopg2://logpuller:password@localhost:5432/logpuller

# Directorio de logs a monitorizar
LOG_DIR=/var/logs/aplicacion
LOG_EXTENSIONS=.log,.txt,.out

# Procesamiento
BATCH_SIZE=500
MAX_FILE_SIZE_MB=500

# Scheduler (Fase 4)
SCHEDULER_CRON=0 2 * * *

# Logging de la aplicación
LOG_LEVEL=INFO
LOG_FILE=logs/logpuller.log
